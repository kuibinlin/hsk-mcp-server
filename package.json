{
  "name": "hsk-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Remote MCP server exposing HSK Chinese vocabulary as tutor-oriented tools for Claude",
  "license": "MIT",
  "author": "Kuibin Lin",
  "homepage": "https://github.com/kuibinlin/hsk-mcp-server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kuibinlin/hsk-mcp-server.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build-seed": "tsx scripts/build-seed.ts",
    "verify-dataset": "tsx scripts/verify-dataset.ts",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "agents": "^0.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@cloudflare/vitest-pool-workers": "^0.14.3",
    "@cloudflare/workers-types": "^4.20260411.1",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  }
}
